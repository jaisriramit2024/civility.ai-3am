__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Node.js
node_modules/
.next/
dist/
dist-ssr/
build/

# IDE & Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# Type checkers
.pyre_configuration
pyrightconfig.json
.mypy_cache/

# Environment variables
.env
.env.local
.env.*.local

# Runtime data
uploads/*.mp4
uploads/*.mov
uploads/*.avi
uploads/*.mkv
uploads/*.webm
frames/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Build & Cache
*.local
.pytest_cache/
.cache/
*.cache

# Test artifacts
test_img.jpg
